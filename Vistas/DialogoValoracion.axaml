<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BibliotecaApp.Vistas.DialogoValoracion"
        Title="Añadir valoración"
        Width="400" Height="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="16" LastChildFill="True">

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
        <Button Content="Guardar" Click="BtnGuardar_Click" Width="80"/>
        <Button Content="Cancelar" Click="BtnCancelar_Click" Width="80"/>
    </StackPanel>

    <StackPanel Spacing="10">

        <TextBlock x:Name="lblTitulo" FontWeight="SemiBold" TextWrapping="Wrap"/>

        <TextBlock Text="Puntuación (0-10):"/>
        <TextBox x:Name="txtPuntuacion"/>

        <TextBlock Text="ID Usuario:"/>
        <TextBox x:Name="txtUsuario"/>

        <TextBlock Text="Comentario (opcional):"/>
        <TextBox x:Name="txtComentario"/>

        <TextBlock Text="Palabras clave (opcional, separadas por comas):"/>
        <TextBox x:Name="txtPalabras"/>

        <TextBlock x:Name="lblError" Foreground="Red" IsVisible="False" TextWrapping="Wrap"/>

    </StackPanel>

    </DockPanel>
</Window>
